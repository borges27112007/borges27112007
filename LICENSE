<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Cronômetro Simples</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 50px;
        }
        #cronometro {
            font-size: 2em;
            margin: 20px 0;
        }
        button {
            margin: 5px;
            padding: 10px 15px;
            font-size: 1em;
        }
    </style>
</head>
<body>

    <h1>Cronômetro</h1>
    <p id="cronometro">00:00:00.0</p>

    <button id="btnLigar">Iniciar</button>
    <button id="btnPausar">Pausar</button>
    <button id="btnResetar">Resetar</button>

    <script>
        const btnLigar = document.querySelector('#btnLigar');
        const btnPausar = document.querySelector('#btnPausar');
        const btnResetar = document.querySelector('#btnResetar');
        const cronometro = document.querySelector('#cronometro');

        let decSeg = 0;
        let contando = false;
        let idContagem;

        function mostraCronometro() {
            decSeg++;
            let ms = decSeg % 10;
            let seg = Math.floor(decSeg / 10);
            let min = Math.floor(seg / 60);
            let hora = Math.floor(min / 60);

            let strHora = (hora < 10) ? '0' + hora : hora;
            let strMin = (min < 10) ? '0' + min : min;
            let strSeg = (seg < 10) ? '0' + seg : seg;

            cronometro.textContent = `${strHora}:${strMin}:${strSeg}.${ms}`;
        }

        btnLigar.addEventListener('click', () => {
            if (contando) return;
            idContagem = setInterval(mostraCronometro, 100);
            btnLigar.textContent = 'Rodando...';
            btnPausar.disabled = false;
            contando = true;
        });

        btnPausar.addEventListener('click', () => {
            if (contando) {
                clearInterval(idContagem);
                btnPausar.textContent = 'Retomar';
                btnLigar.textContent = 'Iniciar';
                contando = false;
            } else {
                idContagem = setInterval(mostraCronometro, 100);
                btnPausar.textContent = 'Pausar';
                btnLigar.textContent = 'Rodando...';
                contando = true;
            }
        });

        btnResetar.addEventListener('click', () => {
            clearInterval(idContagem);
            cronometro.textContent = '00:00:00.0';
            decSeg = 0;
            contando = false;
            btnLigar.textContent = 'Iniciar';
            btnPausar.textContent = 'Pausar';
            btnPausar.disabled = true; // Opcional: desabilita o botão pausar quando resetado
        });

        // Garante que o botão pausar comece desabilitado
        btnPausar.disabled = true;
    </script>

</body>
</html>
